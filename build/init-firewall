#!/bin/bash
# init-firewall: Initialize container network firewall
# This script runs once at container startup and then deletes itself.
#
# Security features:
# - Default-deny egress policy (IPv4 and IPv6)
# - Allowlist-based domain filtering
# - DNS resolution for domain names
# - CIDR notation support for IP ranges
#
set -euo pipefail

# Logging function for debugging
log() {
    echo "[init-firewall] $1" >&2
}

log_error() {
    echo "[init-firewall] ERROR: $1" >&2
}

# Helper: detect IPv6 address (contains colon)
is_ipv6() { case "$1" in *:*) return 0 ;; *) return 1 ;; esac; }

# IPv6 firewall support flag (detected below)
HAS_IP6TABLES=false

# Helper: apply rule to both iptables and ip6tables (only if ip6tables is functional)
fw_both() {
    iptables "$@" 2>/dev/null || true
    if [ "$HAS_IP6TABLES" = "true" ]; then
        ip6tables "$@" 2>/dev/null || true
    fi
}

# State tracking
FIREWALL_INITIALIZED=false
SCRIPT_PATH="$(realpath "$0")"
DEBUG_LOG="/tmp/firewall-init.log"

# Security fix: Always remove script on exit (don't leave executable files around)
# Log debug info to file instead of leaving script behind
cleanup() {
    local exit_code=$?
    if [ "$FIREWALL_INITIALIZED" != "true" ] && [ "${DISABLE_FIREWALL:-false}" != "true" ]; then
        # Log failure details for debugging
        {
            echo "Firewall initialization failed at $(date)"
            echo "Exit code: $exit_code"
            echo "FIREWALL_INITIALIZED: $FIREWALL_INITIALIZED"
            echo "DISABLE_FIREWALL: ${DISABLE_FIREWALL:-false}"
        } > "$DEBUG_LOG" 2>&1
        log_error "Firewall initialization incomplete (exit code: $exit_code). Debug log: $DEBUG_LOG"
    fi
    # Always remove script - security best practice
    rm -f "$SCRIPT_PATH"
}
trap cleanup EXIT

# Handle disabled firewall case
if [ "${DISABLE_FIREWALL:-false}" = "true" ]; then
    log "Firewall disabled by DISABLE_FIREWALL flag"
    exit 0
fi

# Skip firewall for rootless Podman (no NET_ADMIN capability)
if [ "${CLAUDEBOX_RUNTIME_MODE:-docker}" = "podman-rootless" ]; then
    log "Firewall not available in rootless Podman mode (no NET_ADMIN capability)"
    exit 0
fi

log "Initializing firewall rules..."

# Detect ip6tables availability: try adding and removing a test rule
if command -v ip6tables >/dev/null 2>&1; then
    if ip6tables -A OUTPUT -j ACCEPT 2>/dev/null; then
        ip6tables -D OUTPUT -j ACCEPT 2>/dev/null || true
        HAS_IP6TABLES=true
        log "ip6tables: functional"
    else
        log "ip6tables: not functional (kernel module unavailable?)"
    fi
else
    log "ip6tables: not installed"
fi

# If ip6tables is not available, disable IPv6 via sysctl to prevent leaks
if [ "$HAS_IP6TABLES" != "true" ]; then
    log "Disabling IPv6 via sysctl (no ip6tables for firewall control)"
    sysctl -w net.ipv6.conf.all.disable_ipv6=1 2>/dev/null || true
    sysctl -w net.ipv6.conf.default.disable_ipv6=1 2>/dev/null || true
fi

# Flush existing rules (ignore errors if no rules exist)
fw_both -F OUTPUT
fw_both -F INPUT

# Allow DNS queries (required for domain resolution)
fw_both -A OUTPUT -p udp --dport 53 -j ACCEPT
fw_both -A OUTPUT -p tcp --dport 53 -j ACCEPT
fw_both -A INPUT -p udp --sport 53 -j ACCEPT

# Allow loopback interface
fw_both -A OUTPUT -o lo -j ACCEPT
fw_both -A INPUT -i lo -j ACCEPT
iptables -A OUTPUT -s 127.0.0.0/8 -d 127.0.0.0/8 -j ACCEPT 2>/dev/null || true
iptables -A INPUT -s 127.0.0.0/8 -d 127.0.0.0/8 -j ACCEPT 2>/dev/null || true
if [ "$HAS_IP6TABLES" = "true" ]; then
    ip6tables -A OUTPUT -s ::1/128 -d ::1/128 -j ACCEPT 2>/dev/null || true
    ip6tables -A INPUT -s ::1/128 -d ::1/128 -j ACCEPT 2>/dev/null || true
fi

# Allow established connections
fw_both -A OUTPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
fw_both -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT

# Default allowed domains (Anthropic services)
DEFAULT_DOMAINS="api.anthropic.com console.anthropic.com statsig.anthropic.com sentry.io storage.googleapis.com"

ALLOWED_DOMAINS="$DEFAULT_DOMAINS"
ALLOWLIST_FILE="/home/DOCKERUSER/.claudebox/allowlist"

# Domain validation regex: alphanumeric, hyphens, dots, and optional CIDR notation
VALID_DOMAIN_REGEX='^[a-zA-Z0-9]([a-zA-Z0-9.-]*[a-zA-Z0-9])?(/[0-9]+)?$'

# IP detection patterns
IPV4_REGEX='^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+(/[0-9]+)?$'
IPV6_REGEX='^[0-9a-fA-F:]+(/[0-9]+)?$'

# Load custom allowlist if exists
if [ -f "$ALLOWLIST_FILE" ]; then
    log "Loading custom allowlist from $ALLOWLIST_FILE"
    CUSTOM_COUNT=0
    while IFS= read -r line; do
        # Skip comments and empty lines
        case "$line" in
            '#'*|'') continue ;;
        esac
        domain="${line#\*.}"
        domain="$(echo "$domain" | xargs)"
        # Validate domain format before adding
        if [[ -n "$domain" ]] && [[ "$domain" =~ $VALID_DOMAIN_REGEX ]]; then
            ALLOWED_DOMAINS="$ALLOWED_DOMAINS $domain"
            CUSTOM_COUNT=$((CUSTOM_COUNT + 1))
        else
            log_error "Skipping invalid domain format: $domain"
        fi
    done < "$ALLOWLIST_FILE"
    log "Loaded $CUSTOM_COUNT custom domains from allowlist"
else
    log "No custom allowlist found at $ALLOWLIST_FILE"
fi

# Configure allowed domains using ipset (preferred) or iptables fallback
# Check if ipset + iptables -m set is truly functional (full chain test)
IPSET_FUNCTIONAL=false
if command -v ipset >/dev/null 2>&1; then
    # Full functional test: create set, add IP, use in iptables, then cleanup
    if ipset create _firewall_test hash:net 2>/dev/null && \
       ipset add _firewall_test 127.0.0.1 2>/dev/null && \
       iptables -A OUTPUT -m set --match-set _firewall_test dst -j ACCEPT 2>/dev/null; then
        # Full chain works - clean up test rules
        iptables -D OUTPUT -m set --match-set _firewall_test dst -j ACCEPT 2>/dev/null || true
        ipset destroy _firewall_test 2>/dev/null || true
        IPSET_FUNCTIONAL=true
        log "ipset + iptables -m set: functional"
    else
        # Cleanup any partial test state
        iptables -D OUTPUT -m set --match-set _firewall_test dst -j ACCEPT 2>/dev/null || true
        ipset destroy _firewall_test 2>/dev/null || true
        log "ipset or iptables -m set: not functional, using fallback"
    fi
fi

if [ "$IPSET_FUNCTIONAL" = "true" ]; then
    log "Using ipset for domain filtering"
    # Destroy existing sets
    ipset destroy allowed-domains 2>/dev/null || true
    ipset destroy allowed-ips 2>/dev/null || true
    ipset destroy allowed-domains-v6 2>/dev/null || true
    ipset destroy allowed-ips-v6 2>/dev/null || true

    # Create IPv4 sets
    if ! ipset create allowed-domains hash:net 2>/dev/null || \
       ! ipset create allowed-ips hash:net 2>/dev/null; then
        log "Failed to create IPv4 ipsets, falling back to direct rules"
        ipset destroy allowed-domains 2>/dev/null || true
        ipset destroy allowed-ips 2>/dev/null || true
        IPSET_FUNCTIONAL=false
    fi
    # Create IPv6 sets only if ip6tables is functional
    if [ "$IPSET_FUNCTIONAL" = "true" ] && [ "$HAS_IP6TABLES" = "true" ]; then
        if ! ipset create allowed-domains-v6 hash:net family inet6 2>/dev/null || \
           ! ipset create allowed-ips-v6 hash:net family inet6 2>/dev/null; then
            log "Failed to create IPv6 ipsets (IPv4 ipsets still active)"
            ipset destroy allowed-domains-v6 2>/dev/null || true
            ipset destroy allowed-ips-v6 2>/dev/null || true
        fi
    fi
fi

# Helper: add IP to correct ipset based on address family
ipset_add_domain() {
    local ip="$1"
    if is_ipv6 "$ip"; then
        if [ "$HAS_IP6TABLES" = "true" ]; then
            ipset add allowed-domains-v6 "$ip" 2>/dev/null || true
        fi
    else
        ipset add allowed-domains "$ip" 2>/dev/null || true
    fi
}

ipset_add_ip() {
    local ip="$1"
    if is_ipv6 "$ip"; then
        if [ "$HAS_IP6TABLES" = "true" ]; then
            ipset add allowed-ips-v6 "$ip" 2>/dev/null || true
        fi
    else
        ipset add allowed-ips "$ip" 2>/dev/null || true
    fi
}

# Helper: add direct iptables/ip6tables rule for an IP
fw_allow_ip() {
    local ip="$1"
    if is_ipv6 "$ip"; then
        if [ "$HAS_IP6TABLES" = "true" ]; then
            ip6tables -A OUTPUT -d "$ip" -j ACCEPT 2>/dev/null
        fi
    else
        iptables -A OUTPUT -d "$ip" -j ACCEPT 2>/dev/null
    fi
}

# Only proceed with ipset if still functional
if [ "$IPSET_FUNCTIONAL" = "true" ]; then
    DOMAIN_COUNT=0
    RESOLVE_OK=0
    RESOLVE_FAIL=0
    IP_ADDED=0
    for domain in $ALLOWED_DOMAINS; do
        DOMAIN_COUNT=$((DOMAIN_COUNT + 1))
        if [[ "$domain" =~ $IPV4_REGEX ]]; then
            ipset_add_ip "$domain"
            IP_ADDED=$((IP_ADDED + 1))
        elif [[ "$domain" =~ $IPV6_REGEX ]]; then
            ipset_add_ip "$domain"
            IP_ADDED=$((IP_ADDED + 1))
        else
            ips=$(getent ahosts "$domain" 2>/dev/null | awk '{print $1}' | sort -u) || true
            if [ -n "$ips" ]; then
                RESOLVE_OK=$((RESOLVE_OK + 1))
                for ip in $ips; do
                    ipset_add_domain "$ip"
                    IP_ADDED=$((IP_ADDED + 1))
                done
            else
                RESOLVE_FAIL=$((RESOLVE_FAIL + 1))
                log "Warning: DNS failed for: $domain"
            fi
        fi
    done
    log "Resolved $DOMAIN_COUNT domains: $RESOLVE_OK ok, $RESOLVE_FAIL failed, $IP_ADDED IPs added"

    # Apply iptables rules with ipset matching (IPv4)
    iptables -A OUTPUT -m set --match-set allowed-domains dst -j ACCEPT 2>/dev/null || true
    iptables -A OUTPUT -m set --match-set allowed-ips dst -j ACCEPT 2>/dev/null || true
    # Apply ip6tables rules with ipset matching (IPv6) — only if functional
    if [ "$HAS_IP6TABLES" = "true" ]; then
        ip6tables -A OUTPUT -m set --match-set allowed-domains-v6 dst -j ACCEPT 2>/dev/null || true
        ip6tables -A OUTPUT -m set --match-set allowed-ips-v6 dst -j ACCEPT 2>/dev/null || true
    fi
    log "ipset rules applied (IPv4$([ "$HAS_IP6TABLES" = "true" ] && printf ' + IPv6'))"
fi

# Fallback to direct iptables/ip6tables rules if ipset is not functional
if [ "$IPSET_FUNCTIONAL" != "true" ]; then
    log "Using iptables/ip6tables rules directly (ipset not available)"
    IPTABLES_RULES_ADDED=0
    RESOLVE_FAIL=0
    for domain in $ALLOWED_DOMAINS; do
        if [[ "$domain" =~ $IPV4_REGEX ]] || [[ "$domain" =~ $IPV6_REGEX ]]; then
            if fw_allow_ip "$domain"; then
                IPTABLES_RULES_ADDED=$((IPTABLES_RULES_ADDED + 1))
            else
                log "Warning: Failed to add rule for: $domain"
            fi
        else
            ips=$(getent ahosts "$domain" 2>/dev/null | awk '{print $1}' | sort -u) || true
            if [ -z "$ips" ]; then
                RESOLVE_FAIL=$((RESOLVE_FAIL + 1))
                log "Warning: DNS failed for: $domain"
            fi
            for ip in $ips; do
                if fw_allow_ip "$ip"; then
                    IPTABLES_RULES_ADDED=$((IPTABLES_RULES_ADDED + 1))
                else
                    log "Warning: Failed to add rule for: $ip ($domain)"
                fi
            done
        fi
    done
    log "Added $IPTABLES_RULES_ADDED rules ($RESOLVE_FAIL DNS failures)"
fi

# Set default-deny policy (this is the critical security step)
iptables -P OUTPUT DROP
iptables -P INPUT DROP
if [ "$HAS_IP6TABLES" = "true" ]; then
    ip6tables -P OUTPUT DROP
    ip6tables -P INPUT DROP
fi

# Mark initialization as complete
FIREWALL_INITIALIZED=true
if [ "$HAS_IP6TABLES" = "true" ]; then
    log "Firewall initialized successfully. Default policy: DROP (IPv4 + IPv6)"
else
    log "Firewall initialized successfully. Default policy: DROP (IPv4 only, IPv6 disabled via sysctl)"
fi
